<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/primary_dark">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="25dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/button_secondary_start"
                android:centerColor="@color/button_secondary_center"
                android:endColor="@color/button_secondary_end"
                android:centerX="0.5"
                android:centerY="0.5" />
        </shape>
    </item>
</ripple>
