<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/primary_dark_light"
    app:strokeColor="@color/gray_divider"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Title: Top Left -->
        <TextView
            android:id="@+id/list_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_bold"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="Nombre de la Lista" />

        <!-- Movies stack: Bottom Left -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/covers_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/list_title"
            app:layout_constraintEnd_toStartOf="@id/members_layout"
            android:layout_marginEnd="16dp"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/cover_image_1"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_poster"
                app:shapeAppearanceOverlay="@style/CircularImageView"
                app:strokeColor="@color/primary_dark"
                app:strokeWidth="2dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/cover_image_2"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_poster"
                app:shapeAppearanceOverlay="@style/CircularImageView"
                app:strokeColor="@color/primary_dark"
                app:strokeWidth="2dp"
                android:layout_marginStart="-24dp"
                app:layout_constraintStart_toEndOf="@id/cover_image_1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:visibility="gone"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/cover_image_3"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_poster"
                app:shapeAppearanceOverlay="@style/CircularImageView"
                app:strokeColor="@color/primary_dark"
                app:strokeWidth="2dp"
                android:layout_marginStart="-24dp"
                app:layout_constraintStart_toEndOf="@id/cover_image_2"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:visibility="gone"/>

            <FrameLayout
                android:id="@+id/cover_more_container"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_circle_check"
                app:backgroundTint="@color/secondary_dark"
                android:layout_marginStart="-24dp"
                app:layout_constraintStart_toEndOf="@id/cover_image_3"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txt_more_covers"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="+5"
                    android:textColor="@color/gold_light"
                    android:textSize="12sp"
                    android:fontFamily="@font/montserrat_bold"
                    android:gravity="center" />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Right Column: Member Avatars Row -->
        <LinearLayout
            android:id="@+id/members_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/covers_container"
            app:layout_constraintBottom_toBottomOf="@id/covers_container">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/member_avatar_1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_profile"
                app:shapeAppearanceOverlay="@style/CircularImageView"
                app:strokeColor="@color/gold_light"
                app:strokeWidth="1.5dp"
                android:visibility="gone"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/member_avatar_2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_profile"
                app:shapeAppearanceOverlay="@style/CircularImageView"
                app:strokeColor="@color/gold_light"
                app:strokeWidth="1.5dp"
                android:visibility="gone"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/member_avatar_3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_profile"
                app:shapeAppearanceOverlay="@style/CircularImageView"
                app:strokeColor="@color/gold_light"
                app:strokeWidth="1.5dp"
                android:visibility="gone"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/member_avatar_4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_profile"
                app:shapeAppearanceOverlay="@style/CircularImageView"
                app:strokeColor="@color/gold_light"
                app:strokeWidth="1.5dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/txt_more_members"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/gold_dark"
                android:textSize="13sp"
                android:fontFamily="@font/montserrat_bold"
                android:text="+2"
                android:visibility="gone"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
