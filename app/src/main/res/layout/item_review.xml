<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1AFFFFFF"
    app:cardBackgroundColor="@color/primary_dark_light">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Cabecera de la película con fondo degradado translúcido restaurado -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/movie_info_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_review_movie_header"
            android:padding="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/movie_poster_review"
                android:layout_width="48dp"
                android:layout_height="72dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:src="@drawable/placeholder_poster" />

            <TextView
                android:id="@+id/movie_title_review"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:maxLines="2"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/movie_poster_review"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:text="Interstellar" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Foto de perfil del usuario (con separación vertical respecto a la cabecera) -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/user_profile_image"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_default_profile"
            app:civ_border_width="1.5dp"
            app:civ_border_color="@color/primary_light"
            android:layout_marginTop="16dp"
            app:layout_goneMarginTop="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/movie_info_layout" />

        <!-- Nombre del usuario -->
        <TextView
            android:id="@+id/user_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/gold_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/review_stars_layout"
            app:layout_constraintStart_toEndOf="@+id/user_profile_image"
            app:layout_constraintTop_toTopOf="@+id/user_profile_image"
            tools:text="Liam Carter" />

        <!-- Fecha de la reseña -->
        <TextView
            android:id="@+id/review_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textColor="@color/gray_medium"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintEnd_toEndOf="@+id/user_name"
            app:layout_constraintStart_toEndOf="@+id/user_profile_image"
            app:layout_constraintTop_toBottomOf="@+id/user_name"
            tools:text="2 months ago" />

        <!-- Layout para las estrellas -->
        <LinearLayout
            android:id="@+id/review_stars_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/user_profile_image"
            app:layout_constraintBottom_toBottomOf="@+id/user_profile_image">

            <ImageView
                android:id="@+id/star_1"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_star_empty"
                android:contentDescription="@string/star_rating" />

            <ImageView
                android:id="@+id/star_2"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_star_empty"
                android:contentDescription="@string/star_rating" />

            <ImageView
                android:id="@+id/star_3"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_star_empty"
                android:contentDescription="@string/star_rating" />

            <ImageView
                android:id="@+id/star_4"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_star_empty"
                android:contentDescription="@string/star_rating" />

            <ImageView
                android:id="@+id/star_5"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_star_empty"
                android:contentDescription="@string/star_rating" />

        </LinearLayout>

        <!-- Texto de la reseña -->
        <TextView
            android:id="@+id/review_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/primary_light"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            app:layout_constraintTop_toBottomOf="@+id/user_profile_image"/>

        <!-- Layout para botones de like y dislike -->
        <LinearLayout
            android:id="@+id/rating_buttons_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/review_text">

            <!-- Botón de Like -->
            <LinearLayout
                android:id="@+id/like_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/bg_chip_rating"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/like_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_thumb_up"
                    android:contentDescription="@string/like_review"
                    app:tint="@color/gold_light" />

                <TextView
                    android:id="@+id/like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/gold_light"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    tools:text="12" />

            </LinearLayout>

            <!-- Botón de Dislike -->
            <LinearLayout
                android:id="@+id/dislike_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/bg_chip_rating"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/dislike_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_thumb_down"
                    android:contentDescription="@string/dislike_review"
                    app:tint="@color/gold_light" />

                <TextView
                    android:id="@+id/dislike_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/gold_light"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    tools:text="2" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>